# Copy to .env and fill values (used by docker compose)
# Example using a public Elastic Beanstalk URL
# Replace with your EB environment domain after deployment

VNPAY_RETURN_URL=http://luxstayhotel.ap-southeast-1.elasticbeanstalk.com/payment/vnpay-return
VERIFY_EMAIL_BASE_URL=http://your-eb-domain.elasticbeanstalk.com/verify-email
VNPAY_TMN_CODE=DEMOV210
VNPAY_HASH_SECRET=vnpay-demo-secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
