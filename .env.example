# Copy to .env and fill values
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=you@example.com

# Application
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=5000

# Postgres
DB_URL=jdbc:postgresql://postgres:5432/hotel
DB_USERNAME=hotel
DB_PASSWORD=hotel

# MongoDB
MONGODB_URI=mongodb://mongo:27017/hotel
MONGODB_DATABASE=hotel

# Secrets
JWT_SECRET=change-me-strong-secret
VNPAY_HASH_SECRET=change-me-vnpay-secret

# URLs (will use DOMAIN)
RESET_PASSWORD_BASE_URL=https://${DOMAIN}/reset-password
VERIFY_EMAIL_BASE_URL=https://${DOMAIN}/verify-email
VNPAY_RETURN_URL=https://${DOMAIN}/payment/vnpay-return
VNPAY_TMN_CODE=DEMO
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Mail
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Frontend build args
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT_MS=10000
VITE_API_RETRY_COUNT=1
VITE_API_RETRY_DELAY_MS=300
